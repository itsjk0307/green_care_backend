APP_NAME=GreenCare Backend
DEBUG=True
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/greencare_db
NAS_STORAGE_PATH=/mnt/nas/greencare
LOCAL_STORAGE_PATH=./storage/images
MAX_IMAGE_SIZE_MB=10
ALLOWED_HOSTS=*

# Dev server (see run_dev.py). API_BIND_HOST=0.0.0.0 lets phones on Wi-Fi reach your PC.
API_BIND_HOST=0.0.0.0
API_PORT=8000
# Set once to your PC's LAN IP + port; copy the same URL to golf-disease-mobile EXPO_PUBLIC_API_URL.
# For a stable IP, reserve DHCP for this PC on your router.
# DEV_API_PUBLIC_URL=http://192.168.0.61:8000
